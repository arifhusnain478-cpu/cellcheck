# --- LLM provider selection ---
# Which provider the backend uses for reasoning: "anthropic" (default) or "groq".
# Anthropic is the default; Groq is a TEMPORARY fallback while Anthropic API
# access is pending. Switching providers is a one-line change here.
LLM_PROVIDER=anthropic

# --- Anthropic / Claude API (default provider) ---
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Groq / Llama (temporary fallback provider) ---
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Crossref (retracted/related papers for red verdicts) ---
# No API key required. Optionally set a contact email to use Crossref's faster
# "polite pool" (recommended for production). Docs: https://api.crossref.org/
CROSSREF_MAILTO=you@example.com

# --- Demo mode (byte-stable scripted demos) ---
# When true, the three endpoints pin ONLY their LLM-generated text (Quick Check
# explanation + originating lab, STR interpretation, Methods paragraph) to the
# pre-approved values in backend/data/demo_cache.json, so a recorded demo has
# byte-identical wording across takes. Everything else — Cellosaurus identity,
# ICLAC verdict, CLASTR match %/loci, Crossref retractions — still runs LIVE.
# Leave false for normal operation: the cache is then ignored entirely. A line or
# scenario not in the cache also falls back to live generation.
DEMO_MODE=false

# --- Backend ---
# Local dev uses 8000; HuggingFace Spaces expects 7860 (set in the Dockerfile).
PORT=8000

# --- Frontend (Vite) ---
# Must be prefixed with VITE_ to be exposed to the client.
VITE_API_URL=http://localhost:8000
