# Production API base URL, read by src/api/client.js via import.meta.env.VITE_API_URL
# at build time (Vite).
#
# TODO: replace the placeholder below with your real Koyeb backend URL once deployed,
# e.g. https://cellcheck-api-yourorg.koyeb.app  (no trailing slash — client.js appends
# /api/cellcheck). Then redeploy the Vercel frontend so the new value is baked in.
VITE_API_URL=https://cellcheck-api.koyeb.app
