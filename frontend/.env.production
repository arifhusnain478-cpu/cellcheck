# Production API base URL, read by src/api/client.js via import.meta.env.VITE_API_URL
# at build time (Vite). Replace with the real HuggingFace Space URL after the Space
# is created, e.g. https://arifhusnain478-cellcheck-api.hf.space
# (No trailing slash — client.js appends /api/cellcheck.)
VITE_API_URL=https://your-space-name.hf.space
